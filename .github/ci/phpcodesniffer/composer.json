{
  "require"           : {
    "php" : ">=8.4"
  },
  "require-dev"       : {
    "valkyrja/phpcodesniffer" : "^26.1.1"
  },
  "scripts"           : {
    "check"    : "vendor/bin/phpcs --standard=./ruleset.xml ../../../app/src -n && vendor/bin/phpcs --standard=./ruleset.xml ../../../app/tests -n -s",
    "warnings" : "vendor/bin/phpcs --standard=./ruleset.xml ../../../app/src && vendor/bin/phpcs --standard=./ruleset.xml ../../../app/tests -s"
  },
  "minimum-stability" : "dev",
  "prefer-stable"     : true,
  "config"            : {
    "allow-plugins" : {
      "dealerdirect/phpcodesniffer-composer-installer" : true
    }
  }
}
