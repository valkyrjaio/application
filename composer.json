{
  "name"              : "valkyrja/application",
  "type"              : "project",
  "description"       : "The Valkyrja Application.",
  "homepage"          : "https://www.valkyrja.io",
  "keywords"          : [
    "application",
    "valkyrja"
  ],
  "license"           : "MIT",
  "require"           : {
    "php"               : ">=8.4",
    "monolog/monolog"   : "^3.10.0",
    "valkyrja/valkyrja" : "^25.25.1"
  },
  "require-dev"       : {
    "filp/whoops"     : "^2.18.4",
    "phpunit/phpunit" : "^12.5.8"
  },
  "config"            : {
    "optimize-autoloader" : true,
    "preferred-install"   : "dist",
    "sort-packages"       : true
  },
  "autoload"          : {
    "psr-4" : {
      "App\\" : "app/src/App/"
    }
  },
  "autoload-dev"      : {
    "psr-4" : {
      "App\\Tests\\" : "app/tests/Tests/"
    }
  },
  "scripts"           : {
    "post-root-package-install" : [
      "php -r \"file_exists('app/src/App/Cli/Provider/Data/CliRoutingDataProvider.php') || copy('app/src/App/Cli/Provider/Data/CliRoutingDataProvider.example.php', 'app/src/App/Cli/Provider/Data/CliRoutingDataProvider.php');\"",
      "php -r \"file_exists('app/src/App/Cli/Provider/Data/ContainerDataProvider.php') || copy('app/src/App/Cli/Provider/Data/ContainerDataProvider.example.php', 'app/src/App/Cli/Provider/Data/ContainerDataProvider.php');\"",
      "php -r \"file_exists('app/src/App/Cli/Provider/Data/EventDataProvider.php') || copy('app/src/App/Cli/Provider/Data/EventDataProvider.example.php', 'app/src/App/Cli/Provider/Data/EventDataProvider.php');\"",
      "php -r \"file_exists('app/src/App/Http/Provider/Data/HttpRoutingDataProvider.php') || copy('app/src/App/Http/Provider/Data/HttpRoutingDataProvider.example.php', 'app/src/App/Http/Provider/Data/HttpRoutingDataProvider.php');\"",
      "php -r \"file_exists('app/src/App/Http/Provider/Data/ContainerDataProvider.php') || copy('app/src/App/Http/Provider/Data/ContainerDataProvider.example.php', 'app/src/App/Http/Provider/Data/ContainerDataProvider.php');\"",
      "php -r \"file_exists('app/src/App/Http/Provider/Data/EventDataProvider.php') || copy('app/src/App/Http/Provider/Data/EventDataProvider.example.php', 'app/src/App/Http/Provider/Data/EventDataProvider.php');\"",
      "php -r \"file_exists('app/src/App/Http/Config.php') || copy('app/src/App/Http/Config.example.php', 'app/src/App/Http/Config.php');\"",
      "php -r \"file_exists('app/src/App/Cli/Config.php') || copy('app/src/App/Cli/Config.example.php', 'app/src/App/Cli/Config.php');\"",
      "php -r \"file_exists('app/src/App/Http/Env.php') || copy('app/src/App/Http/Env.example.php', 'app/src/App/Http/Env.php');\"",
      "php -r \"file_exists('app/src/App/Cli/Env.php') || copy('app/src/App/Cli/Env.example.php', 'app/src/App/Cli/Env.php');\"",
      "php -r \"file_exists('app/tests/Tests/Env.php') || copy('app/tests/Tests/Env.example.php', 'app/tests/Tests/EnvTest.php');\""
    ]
  },
  "suggest"           : {
  },
  "minimum-stability" : "dev",
  "prefer-stable"     : true,
  "extra"             : {
    "valkyrja" : {
      "dont-discover" : []
    }
  }
}
